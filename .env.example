# Copie para .env e ajuste se necessário. Nunca commitar o .env real.

# Postgres (um banco por serviço, mesma instância local)
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_MULTIPLE_DATABASES=inscricoes,partidas,ranking

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Auth (contas e papeis por torneio)
# segredo compartilhado entre inscricoes-service e partidas-service para
# assinar/validar o token de sessao (HMAC-SHA256). OBRIGATORIO: sem ele os
# servicos se recusam a subir (os scripts de dev definem este valor sozinhos).
AUTH_SECRET=championship-dev-secret-trocar-em-producao

# OpenTelemetry
# servicos Spring exportam via OTLP/HTTP (porta 4318); 4317 e o endpoint gRPC
OTEL_EXPORTER_OTLP_HTTP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Langfuse (mcp-agent-service)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM provider (mcp-agent-service, generate_match_recap)
ANTHROPIC_API_KEY=
